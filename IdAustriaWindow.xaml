<Window x:Class="miPDFsign.IdAustriaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ID-Austria Signature"
        Width="900" Height="700"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Info bar (background + text updated on success) -->
        <Border x:Name="InfoBar" Grid.Row="0" Background="#F0F8FF"
                BorderBrush="#B0C4DE" BorderThickness="0,0,0,1"
                Padding="14,10">
            <TextBlock x:Name="TbInfoBar"
                       FontSize="13" FontWeight="Normal" Foreground="#1A3C5E" TextWrapping="Wrap"/>
        </Border>

        <!-- WebBrowser -->
        <WebBrowser x:Name="Browser" Grid.Row="1"
                    Navigating="Browser_Navigating"
                    LoadCompleted="Browser_LoadCompleted"/>

        <!-- Status / Cancel -->
        <Border Grid.Row="2" Background="#F9F9F9"
                BorderBrush="#D1D1D6" BorderThickness="0,1,0,0"
                Padding="14,8">
            <Grid>
                <TextBlock x:Name="TbStatus"
                           Text="Connecting to A-Trust…"
                           FontSize="12" Foreground="#6C6C70"
                           VerticalAlignment="Center"/>
                <Button x:Name="BtnCancel"
                        Content="Cancel"
                        HorizontalAlignment="Right"
                        Height="32" Padding="14,0"
                        FontSize="13"
                        Background="White" BorderBrush="#C7C7CC" BorderThickness="1"
                        Click="BtnCancel_Click" Cursor="Hand"/>
            </Grid>
        </Border>
    </Grid>
</Window>
