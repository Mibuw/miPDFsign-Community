<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <appSettings>

    <!--
      LogFile:  Path to the log file.
                Environment variables are expanded (e.g. %APPDATA%, %TEMP%).
                If LogRolling=true and the path contains no {date} placeholder,
                the date is automatically inserted before the extension.
                Example without placeholder : %APPDATA%\miPDFsign\mipdfsign.log
                                          → mipdfsign_2026-06-12.log  (suffix)
                                          → 2026-06-12_mipdfsign.log  (prefix)
                Example with placeholder  : %APPDATA%\miPDFsign\mipdfsign_{date}.log
                                          → mipdfsign_2026-06-12.log
                Leave empty to disable logging.
    -->
    <add key="LogFile" value="%APPDATA%\miPDFsign\mipdfsign.log"/>

    <!--
      LogLevel: Minimum level of logged entries.
                Possible values: DEBUG, INFO, WARN, ERROR
    -->
    <add key="LogLevel" value="INFO"/>

    <!--
      LogRolling: Create a new log file every day.
                  true  – The date is embedded in the file name;
                          at the day change it automatically switches to the new file.
                  false – Always write to the same file (default).
    -->
    <add key="LogRolling" value="false"/>

    <!--
      LogFileDatePattern: Date format used in the file name (only when LogRolling=true).
                          Default: yyyy-MM-dd  → 2026-06-12
                          More examples:
                            yyyyMMdd   → 20260612
                            yyyy_MM_dd → 2026_06_12
    -->
    <add key="LogFileDatePattern" value="yyyy-MM-dd"/>

    <!--
      LogFileDatePosition: Where the date appears in the file name (only when LogRolling=true
                           and when no {date} placeholder is set in LogFile).
                           suffix → mipdfsign_2026-06-12.log  (default)
                           prefix → 2026-06-12_mipdfsign.log
                           If {date} is placed directly in LogFile, this setting is ignored.
    -->
    <add key="LogFileDatePosition" value="suffix"/>

    <!--
      LogMaxDays: Automatically delete old rolling log files after N days.
                  0 = never delete (default).
                  Only evaluated when LogRolling=true.
    -->
    <add key="LogMaxDays" value="0"/>

    <!--
      ForcePortraitOrientation: Automatically rotate the Wacom One screen orientation to
                                portrait at startup if it is in landscape.
                                true  – Orientation is rotated at startup and restored on
                                        exit (default).
                                false – Orientation is not changed.
    -->
    <add key="ForcePortraitOrientation" value="true"/>

    <!--
      BiometricCertPath: Path to a PFX file used for encrypting the biometric
                         signature data.
                         If empty: A new RSA-3072 certificate is automatically generated and
                         stored as "biometric_key.pfx" next to the signed document.
    -->
    <add key="BiometricCertPath" value=""/>

    <!--
      BiometricCertPassword: Password of the PFX file specified under BiometricCertPath.
                             Leave empty if no password is set.
    -->
    <add key="BiometricCertPassword" value=""/>

    <!--
      SaveAsDialog: Controls where the signed document is saved.
                    true  – When saving, a "Save As" dialog is shown,
                            in which the target folder and file name can be freely chosen
                            (default).
                    false – Save directly, without prompting, to the directory specified
                            under TargetDirectory (or to the folder of the
                            source document if TargetDirectory is empty).
    -->
    <add key="SaveAsDialog" value="true"/>

    <!--
      TargetDirectory: Target directory for the signed document.
                       Environment variables are expanded (e.g. %USERPROFILE%, %TEMP%).
                       - With SaveAsDialog=false: Storage location for the finished document
                         (created if needed). Empty = folder of the source document.
                       - With SaveAsDialog=true : Start directory of the dialog
                         (empty = folder of the source document).
                       The file name is always "<OriginalName>_signed.pdf".
    -->
    <add key="TargetDirectory" value=""/>

    <!--
      UseTimestamp: Controls whether an RFC-3161 timestamp is requested at all.
                    true  – Signatures receive a TSA timestamp (PAdES Baseline-T),
                            and the archive timestamp (PAdES-LTA) is added (default).
                    false – No timestamp; the signature remains PAdES Baseline-B and
                            NO LTA document timestamp is created. (LTV/DSS remains
                            unaffected.)
                    Note: For the short-lived FES certificate (10 min), only the
                    timestamp ensures long-term validity – so set UseTimestamp=false only
                    deliberately.
    -->
    <add key="UseTimestamp" value="true"/>

    <!--
      TimestampServers: List of RFC-3161 timestamp servers (TSA) to use.
                        Separate multiple URLs with a semicolon ";"; they are tried in order
                        until one responds.
                        Leave empty = built-in default list (GlobalSign, Sectigo, Entrust).
                        Example A-Trust (paid subscription):
                          http://tsa.a-trust.at/tsa
    -->
    <add key="TimestampServers" value="http://timestamp.globalsign.com/tsa/r6advanced1;http://timestamp.sectigo.com/;http://timestamp.entrust.net/TSS/RFC3161sha2TS"/>

  </appSettings>
</configuration>
